# Application defaults
CONFIG_UDP_LCD_PORT=2400
CONFIG_LCD_I2C_SDA_PIN=4
CONFIG_LCD_I2C_SCL_PIN=5
CONFIG_LCD_I2C_ADDR=0x3F
CONFIG_LCD_DEFAULT_COLS=20
CONFIG_LCD_DEFAULT_ROWS=4
CONFIG_LCD_I2C_FREQ_HZ=100000
CONFIG_HEARTBEAT_LED_GPIO=12
CONFIG_WIFI_LED_GPIO=13
CONFIG_WIFI_STA_MAX_RETRIES=3
CONFIG_WIFI_STA_RETRY_INTERVAL_MS=500

# FreeRTOS
CONFIG_FREERTOS_HZ=1000

# Partition table
CONFIG_PARTITION_TABLE_SINGLE_APP=y

# Log level
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
