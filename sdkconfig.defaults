# Application defaults
CONFIG_UDP_LCD_PORT=5000
CONFIG_LCD_I2C_SDA_PIN=4
CONFIG_LCD_I2C_SCL_PIN=5
CONFIG_LCD_I2C_ADDR=0x3F
CONFIG_LCD_DEFAULT_COLS=20
CONFIG_LCD_DEFAULT_ROWS=4
CONFIG_LCD_I2C_FREQ_HZ=100000

# FreeRTOS
CONFIG_FREERTOS_HZ=1000

# Partition table
CONFIG_PARTITION_TABLE_SINGLE_APP=y

# Log level
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
